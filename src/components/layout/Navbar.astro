---
import { Image } from 'astro:assets';
---

<nav
  x-data="navbar()"
  @scroll.window="handleScroll()"
  :class="{ 'scrolled': scrolled, '-translate-y-full': hidden }"
  class="navbar fixed top-0 left-0 right-0 z-[1000]"
>
  <div class="flex justify-between items-center max-w-[1400px] mx-auto px-5">
    <a href="#hero">
      <Image
        src="/assets/images/rz-powerhouse-logo-negative.png"
        alt="RZ Power House - Gimnasio Powerlifting Sabadell"
        class="h-9 md:h-10 w-auto"
        width={200}
        height={50}
        loading="eager"
      />
    </a>

    <ul
      class="fixed top-0 right-0 translate-x-full w-3/4 max-w-[320px] h-dvh bg-black border-l border-[var(--gray-light)] flex flex-col justify-center items-center gap-8 z-[1001] p-8 overscroll-contain [transition:transform_350ms_cubic-bezier(0.4,0,0.2,1)] md:static md:w-auto md:max-w-none md:h-auto md:bg-transparent md:border-none md:flex-row md:gap-6 md:p-0 md:translate-x-0"
      :class="{ 'translate-x-0': open }"
    >
      <li><a href="#hero"         @click="open = false" class="nav-link-item">Inicio</a></li>
      <li><a href="#about"        @click="open = false" class="nav-link-item">Nosotros</a></li>
      <li><a href="#services"     @click="open = false" class="nav-link-item">Servicios</a></li>
      <li><a href="#gallery"      @click="open = false" class="nav-link-item">Galería</a></li>
      <li><a href="#products"     @click="open = false" class="nav-link-item">Productos</a></li>
      <li><a href="#testimonials" @click="open = false" class="nav-link-item">Opiniones</a></li>
      <li><a href="#contact"      @click="open = false" class="nav-link-item">Contacto</a></li>
    </ul>

    <button
      class="hamburger-btn md:hidden"
      :class="{ 'active': open }"
      @click="open = !open"
      :aria-expanded="open"
      aria-label="Abrir menú de navegación"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>
