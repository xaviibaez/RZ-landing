---
import { gallerySections, galleryImages } from '../../data/gallery';

const imagesJson = JSON.stringify(galleryImages);
---

<section id="gallery" class="bg-[var(--gray-dark)]" data-analytics="gallery">
  <div class="container-fluid">
    <h2 class="section-title reveal-text center mb-10">EL TEMPLO</h2>

    <div
      x-data="gallery()"
      data-images={imagesJson}
      @keydown.escape.window="close()"
    >
      <!-- Thumbnails grid -->
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 sm:gap-3 lg:grid-cols-5 lg:gap-4">
        {gallerySections.map((section) => (
          <div
            class="gallery-item"
            @click={`open('${section.key}', 0)`}
            role="button"
            tabindex="0"
            aria-label={`Ver galería: ${section.label}`}
            @keydown.enter={`open('${section.key}', 0)`}
          >
            <div class="gallery-thumb">
              <picture>
                <source srcset={section.thumbnail.srcAvif} type="image/avif" />
                <source srcset={section.thumbnail.srcWebp} type="image/webp" />
                <img
                  src={section.thumbnail.src}
                  alt={section.thumbnail.alt}
                  class="gallery-img"
                  loading="lazy"
                  width="400"
                  height="400"
                />
              </picture>
              <div class="gallery-overlay">
                <span class="gallery-icon">&#43;</span>
              </div>
            </div>
            <div class="gallery-label">
              <p>{section.label}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Modal -->
      <div
        class="modal-overlay"
        x-show="isOpen"
        x-transition:enter="modal-enter"
        x-transition:enter-start="modal-enter-start"
        x-transition:enter-end="modal-enter-end"
        x-transition:leave="modal-leave"
        x-transition:leave-start="modal-enter-end"
        x-transition:leave-end="modal-enter-start"
        style="display: none;"
        @click.self="close()"
      >
        <button
          class="absolute top-4 right-4 text-white text-5xl leading-none p-2 z-[10000] hover:text-[var(--accent-red)] transition-colors duration-200"
          @click="close()"
          aria-label="Cerrar galería"
        >×</button>

        <div
          class="flex items-center gap-4 w-full max-w-[90vw] px-2 lg:gap-8"
          @touchstart.passive="touchStartX = $event.touches[0].clientX"
          @touchend.passive="onTouchEnd($event)"
        >
          <button
            class="carousel-nav-btn"
            @click="prev()"
            :disabled="images.length <= 1"
            aria-label="Imagen anterior"
          >&#10094;</button>

          <div class="flex-1 relative flex items-center justify-center">
            <img
              :src="images[currentIndex]?.src"
              :alt="images[currentIndex]?.alt"
              class="max-h-[80vh] max-w-full object-contain border border-[var(--gray-light)]"
              loading="lazy"
            />
            <div
              class="absolute bottom-[-2rem] left-1/2 -translate-x-1/2 text-xs text-white/50 tracking-[0.1em]"
              x-text="`${currentIndex + 1} / ${images.length}`"
            ></div>
          </div>

          <button
            class="carousel-nav-btn"
            @click="next()"
            :disabled="images.length <= 1"
            aria-label="Imagen siguiente"
          >&#10095;</button>
        </div>
      </div>
    </div>
  </div>
</section>
