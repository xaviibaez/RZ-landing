---
import { gallerySections, galleryImages } from '../../data/gallery';
---

<section id="gallery" class="gallery" data-analytics="gallery">
  <div class="container-fluid">
    <h2 class="section-title reveal-text center">EL TEMPLO</h2>

    <div x-data="gallery()" @keydown.escape.window="close()">
      <!-- Thumbnails grid -->
      <div class="gallery-grid">
        {gallerySections.map((section) => (
          <div
            class="gallery-item"
            @click={`open('${section.key}', 0)`}
            role="button"
            tabindex="0"
            aria-label={`Ver galería: ${section.label}`}
            @keydown.enter={`open('${section.key}', 0)`}
          >
            <div class="gallery-thumb">
              <picture>
                <source srcset={section.thumbnail.srcAvif} type="image/avif" />
                <source srcset={section.thumbnail.srcWebp} type="image/webp" />
                <img
                  src={section.thumbnail.src}
                  alt={section.thumbnail.alt}
                  class="gallery-img"
                  loading="lazy"
                  width="400"
                  height="400"
                />
              </picture>
              <div class="gallery-overlay">
                <span class="gallery-zoom">&#43;</span>
              </div>
            </div>
            <div class="gallery-label">
              <p>{section.label}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Modal -->
      <div
        class="carousel-modal"
        x-show="isOpen"
        x-transition:enter="modal-enter"
        x-transition:enter-start="modal-enter-start"
        x-transition:enter-end="modal-enter-end"
        x-transition:leave="modal-leave"
        x-transition:leave-start="modal-enter-end"
        x-transition:leave-end="modal-enter-start"
        style="display: none;"
        @click.self="close()"
      >
        <button class="carousel-close" @click="close()" aria-label="Cerrar galería">×</button>

        <div class="carousel-content"
          @touchstart.passive="touchStartX = $event.touches[0].clientX"
          @touchend.passive="onTouchEnd($event)"
        >
          <button
            class="carousel-btn carousel-prev"
            @click="prev()"
            :disabled="images.length <= 1"
            aria-label="Imagen anterior"
          >&#10094;</button>

          <div class="carousel-media">
            <img
              :src="images[currentIndex]?.src"
              :alt="images[currentIndex]?.alt"
              class="carousel-image"
              loading="lazy"
            />
            <div class="carousel-counter" x-text="`${currentIndex + 1} / ${images.length}`"></div>
          </div>

          <button
            class="carousel-btn carousel-next"
            @click="next()"
            :disabled="images.length <= 1"
            aria-label="Imagen siguiente"
          >&#10095;</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ galleryImages }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('gallery', () => ({
      isOpen: false,
      images: [],
      currentIndex: 0,
      touchStartX: 0,

      open(categoryKey, index) {
        this.images = galleryImages[categoryKey] || [];
        this.currentIndex = index;
        this.isOpen = true;
        document.body.style.overflow = 'hidden';
      },

      close() {
        this.isOpen = false;
        document.body.style.overflow = '';
      },

      prev() {
        this.currentIndex = (this.currentIndex - 1 + this.images.length) % this.images.length;
      },

      next() {
        this.currentIndex = (this.currentIndex + 1) % this.images.length;
      },

      onTouchEnd(e) {
        const diff = this.touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          diff > 0 ? this.next() : this.prev();
        }
      },
    }));
  });
</script>

<style>
  .gallery {
    background: var(--gray-dark);
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .gallery .section-title {
    margin-bottom: 2.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .gallery-item {
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .gallery-thumb {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .gallery-zoom {
    color: #fff;
    font-size: 2.5rem;
    font-weight: 300;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @media (hover: hover) {
    .gallery-item:hover .gallery-img {
      transform: scale(1.06);
    }

    .gallery-item:hover .gallery-overlay {
      background: rgba(196, 30, 58, 0.35);
    }

    .gallery-item:hover .gallery-zoom {
      opacity: 1;
      transform: scale(1);
    }
  }

  .gallery-label {
    background: rgba(0, 0, 0, 0.85);
    padding: 0.6rem 1rem;
    text-align: center;
  }

  .gallery-label p {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Modal ── */

  .carousel-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    line-height: 1;
    padding: 0.5rem;
    z-index: 10000;
    transition: color 0.2s ease;
  }

  .carousel-close:hover {
    color: var(--accent-red);
  }

  .carousel-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 90vw;
    padding: 0 0.5rem;
  }

  .carousel-media {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-image {
    max-height: 80vh;
    max-width: 100%;
    object-fit: contain;
    border: 1px solid var(--gray-light);
  }

  .carousel-counter {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.1em;
  }

  .carousel-btn {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 1.25rem;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .carousel-btn:hover:not(:disabled) {
    background: var(--accent-red);
    border-color: var(--accent-red);
  }

  .carousel-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Modal transitions */
  .modal-enter { transition: opacity 0.2s ease; }
  .modal-enter-start { opacity: 0; }
  .modal-enter-end { opacity: 1; }
  .modal-leave { transition: opacity 0.2s ease; }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }

    .gallery {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .carousel-content {
      gap: 2rem;
    }

    .carousel-btn {
      width: 3.5rem;
      height: 3.5rem;
      font-size: 1.5rem;
    }
  }
</style>
