---
import { services } from '../../data/services';
---

<section id="services" class="bg-black">
  <div class="container">
    <h2 class="section-title reveal-text center mb-10">NUESTROS SERVICIOS</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service, i) => (
        <div
          class="service-card border border-[var(--gray-light)] p-7 bg-[var(--gray-dark)] lg:p-8"
          style={`animation-delay: ${i * 80}ms`}
        >
          <div class="text-[var(--accent-gold)] text-xl mb-3" aria-hidden="true">◆</div>
          <h3 class="text-[0.9rem] font-black tracking-[0.08em] uppercase mb-3 text-white">{service.title}</h3>
          <p class="text-[0.875rem] text-white/65 leading-[1.7]">{service.description}</p>
          <a href="#contact" class="inline-block mt-4 text-[0.75rem] font-black tracking-[0.1em] uppercase text-[var(--accent-gold)] hover-safe:text-white transition-colors duration-200">Consultar →</a>
        </div>
      ))}
    </div>
  </div>
</section>
