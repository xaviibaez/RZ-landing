        </div>
      </div>
    </div>

    <!-- Colaborators -->
    <div class="border-t border-[var(--gray-light)] pt-8 text-center">
      <p class="text-[0.7rem] tracking-[0.15em] text-white/35 uppercase mb-3">Colaboradores</p>
      <nav class="flex flex-wrap items-center justify-center gap-2" aria-label="Enlaces a colaboradores">
