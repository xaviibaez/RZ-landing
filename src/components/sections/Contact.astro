        <a href="https://www.instagram.com/maniakfitness/" target="_blank" rel="noopener noreferrer" class="colaborator-link">Maniak Fitness</a>
        <span class="text-white/20 text-xs" aria-hidden="true">|</span>
        <a href="https://www.hammerstrength.com" target="_blank" rel="noopener noreferrer" class="colaborator-link">Hammer Strength</a>
      </nav>
    </div>

  </div>
</section>
