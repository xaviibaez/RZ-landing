---
---

<section id="contact" class="bg-[var(--gray-dark)]">
  <div class="container">

    <div class="mb-10">
      <h2 class="section-title reveal-text">ÚNETE AL TEMPLO</h2>
      <p class="mt-3 text-white/60 text-[0.95rem]">Comienza tu transformación hoy. Primera sesión gratuita.</p>
    </div>

    <div class="grid grid-cols-1 gap-12 mb-12 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">

      <!-- Form -->
      <div x-data="contactForm()">
        <!-- Toast -->
        <div
          class="flex items-center gap-3 p-4 px-5 mb-5 rounded-sm text-sm font-semibold"
          :class="{
            'bg-green-950 border border-green-800 text-green-200': status === 'success',
            'bg-red-950 border border-red-800 text-red-200': status === 'error'
          }"
          x-show="status !== null"
          x-transition:enter="toast-transition"
          x-transition:enter-start="toast-hidden"
          x-transition:enter-end="toast-visible"
          style="display: none;"
          role="alert"
        >
          <span x-text="status === 'success' ? '✓' : '✗'" class="text-lg flex-shrink-0"></span>
          <span x-text="message"></span>
        </div>

        <form @submit.prevent="submit()" novalidate class="flex flex-col gap-4">
          <input
            type="text"
            name="nombre"
            placeholder="NOMBRE COMPLETO"
            x-model="form.nombre"
            required
            autocomplete="name"
            class="form-field"
          />
          <input
            type="email"
            name="correo"
            placeholder="EMAIL"
            x-model="form.correo"
            required
            autocomplete="email"
            class="form-field"
          />
          <input
            type="tel"
            name="telefono"
            placeholder="TELÉFONO"
            x-model="form.telefono"
            pattern="[0-9]{9}"
            maxlength="9"
            required
            autocomplete="tel"
            class="form-field"
          />
          <select
            name="interes"
            x-model="form.interes"
            required
            class="form-field form-select"
          >
            <option value="">INTERESADO EN...</option>
            <option value="Powerlifting">Powerlifting</option>
            <option value="Halterofilia">Halterofilia</option>
            <option value="Entrenamiento personal">Entrenamiento personal</option>
            <option value="Planificaciones nutricionales">Planificaciones nutricionales</option>
            <option value="Preparación de oposiciones">Preparación de oposiciones</option>
            <option value="Club Powerlifting RZ Power Team">Club Powerlifting RZ Power Team</option>
          </select>
          <textarea
            name="mensaje"
            placeholder="MENSAJE (OPCIONAL)"
            rows="4"
            x-model="form.mensaje"
            class="form-field form-textarea"
          ></textarea>
          <button
            type="submit"
            class="submit-btn"
            :disabled="loading"
            x-text="loading ? 'ENVIANDO...' : 'ENVIAR MENSAJE'"
          ></button>
        </form>
      </div>

      <!-- Info -->
      <div class="flex flex-col gap-6">
        <div>
          <h4 class="text-[0.7rem] font-bold tracking-[0.15em] text-[var(--accent-gold)] uppercase mb-1.5">UBICACIÓN</h4>
          <p class="text-[0.875rem] text-white/70 leading-[1.6]">
            Carrer de Permanyer, 316<br />Sabadell 08205
          </p>
          <a
            href="https://maps.app.goo.gl/NtYGLrKkmqyefsky5"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 mt-2 text-[0.75rem] font-black tracking-[0.08em] uppercase text-[var(--accent-gold)] hover-safe:text-white transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            Ver en Google Maps
          </a>
        </div>
        <div>
          <h4 class="text-[0.7rem] font-bold tracking-[0.15em] text-[var(--accent-gold)] uppercase mb-1.5">HORARIO</h4>
          <p class="text-[0.875rem] text-white/70 leading-[1.6]">De lunes a domingo<br />24h</p>
        </div>
        <div>
          <h4 class="text-[0.7rem] font-bold tracking-[0.15em] text-[var(--accent-gold)] uppercase mb-1.5">CONTACTO</h4>
          <a href="mailto:antoni-10-23@hotmail.com" class="block">
            <p class="text-[0.875rem] text-white/70 leading-[1.6] hover:text-white transition-colors duration-200">antoni-10-23@hotmail.com</p>
          </a>
          <a href="tel:+34677624775" class="block">
            <p class="text-[0.875rem] text-white/70 leading-[1.6] hover:text-white transition-colors duration-200">677 62 47 75</p>
          </a>
        </div>

        <div class="flex flex-wrap gap-3 mt-2">
          <a href="https://wa.me/34677624775" target="_blank" rel="noopener noreferrer"
            class="social-link social-link-whatsapp" aria-label="Contactar por WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
