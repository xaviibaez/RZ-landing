            </svg>
            <span>Instagram</span>
          </a>
          <a href="https://www.tiktok.com/@antonirzpower" target="_blank" rel="noopener noreferrer"
            class="social-link social-link-tiktok" data-track="tiktok_click" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
            </svg>
            <span>TikTok</span>
          </a>
          <a href="https://www.youtube.com/channel/UCJrHJodMPMHErA3_szj_UMQ" target="_blank" rel="noopener noreferrer"
            class="social-link social-link-youtube" data-track="youtube_click" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
