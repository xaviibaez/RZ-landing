---
---

<section id="contact" class="contact">
  <div class="container">
    <div class="contact-header">
      <h2 class="section-title reveal-text">ÚNETE AL TEMPLO</h2>
      <p class="contact-subtitle">Comienza tu transformación hoy. Primera sesión gratuita.</p>
    </div>

    <div class="contact-grid">
      <!-- Form -->
      <div class="contact-form-wrap" x-data="contactForm()">
        <!-- Toast notification -->
        <div
          class="toast"
          x-show="status !== null"
          :class="{ 'toast-success': status === 'success', 'toast-error': status === 'error' }"
          x-transition:enter="toast-enter"
          x-transition:enter-start="toast-start"
          x-transition:enter-end="toast-end"
          style="display: none;"
          role="alert"
        >
          <span x-text="status === 'success' ? '✓' : '✗'" class="toast-icon"></span>
          <span x-text="message"></span>
        </div>

        <form @submit.prevent="submit()" novalidate>
          <div class="form-group">
            <input
              type="text"
              name="nombre"
              placeholder="NOMBRE COMPLETO"
              x-model="form.nombre"
              required
              autocomplete="name"
            />
          </div>
          <div class="form-group">
            <input
              type="email"
              name="correo"
              placeholder="EMAIL"
              x-model="form.correo"
              required
              autocomplete="email"
            />
          </div>
          <div class="form-group">
            <input
              type="tel"
              name="telefono"
              placeholder="TELÉFONO"
              x-model="form.telefono"
              pattern="[0-9]{9}"
              maxlength="9"
              required
              autocomplete="tel"
            />
          </div>
          <div class="form-group">
            <select name="interes" x-model="form.interes" required>
              <option value="">INTERESADO EN...</option>
              <option value="Powerlifting">Powerlifting</option>
              <option value="Halterofilia">Halterofilia</option>
              <option value="Entrenamiento personal">Entrenamiento personal</option>
              <option value="Planificaciones nutricionales">Planificaciones nutricionales</option>
              <option value="Preparación de oposiciones">Preparación de oposiciones</option>
              <option value="Club Powerlifting RZ Power Team">Club Powerlifting RZ Power Team</option>
            </select>
          </div>
          <div class="form-group">
            <textarea
              name="mensaje"
              placeholder="MENSAJE (OPCIONAL)"
              rows="4"
              x-model="form.mensaje"
            ></textarea>
          </div>
          <button
            type="submit"
            class="submit-btn"
            :disabled="loading"
            x-text="loading ? 'ENVIANDO...' : 'ENVIAR MENSAJE'"
          ></button>
        </form>
      </div>

      <!-- Info -->
      <div class="contact-info">
        <div class="info-item">
          <h4>UBICACIÓN</h4>
          <a href="https://maps.app.goo.gl/NtYGLrKkmqyefsky5" target="_blank" rel="noopener noreferrer">
            <p>Carrer de Permanyer, 316<br />Sabadell 08205</p>
          </a>
        </div>
        <div class="info-item">
          <h4>HORARIO</h4>
          <p>De lunes a domingo<br />24h</p>
        </div>
        <div class="info-item">
          <h4>CONTACTO</h4>
          <a href="mailto:antoni-10-23@hotmail.com">
            <p>antoni-10-23@hotmail.com</p>
          </a>
          <a href="tel:+34677624775">
            <p>677 62 47 75</p>
          </a>
        </div>

        <div class="social-links">
          <a href="https://wa.me/34677624775" target="_blank" rel="noopener noreferrer" class="social-link social-link-whatsapp" aria-label="Contactar por WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>WhatsApp</span>
          </a>
          <a href="https://www.instagram.com/rzpowerhouse/" target="_blank" rel="noopener noreferrer" class="social-link social-link-instagram" data-track="instagram_click" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
